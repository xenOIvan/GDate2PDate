{
    "manifest_version":  3,
    "name":  "GDate2PDate - Gregorian to Jalali Live WebPage Date Converter",
    "name__fa":  "تبدیل تاریخ میلادی به شمسی",
    "version":  "1404.8.25",
    "description":  "Chrome Extension Automatically Converts Gregorian dates to Jalali (Persian) dates | تبدیل خودکار تاریخ میلادی به شمسی در هر صفحه وب",
    "author":  "محمد کنی",
    "permissions":  [
                        "storage",
                        "activeTab"
                    ],
    "host_permissions":  [
                             "\u003call_urls\u003e"
                         ],
    "content_scripts":  [
                            {
                                "matches":  [
                                                "\u003call_urls\u003e"
                                            ],
                                "js":  [
                                           "content.js"
                                       ],
                                "run_at":  "document_end",
                                "all_frames":  false
                            }
                        ],
    "background":  {
                       "service_worker":  "background.js"
                   },
    "action":  {
                   "default_popup":  "popup.html",
                   "default_icon":  {
                                        "16":  "icons/icon16.png",
                                        "48":  "icons/icon48.png",
                                        "128":  "icons/icon128.png"
                                    },
                   "default_title":  "تبدیل تاریخ میلادی به شمسی | Gregorian to Jalali"
               },
    "icons":  {
                  "16":  "icons/icon16.png",
                  "48":  "icons/icon48.png",
                  "128":  "icons/icon128.png"
              },
    "web_accessible_resources":  [
                                     {
                                         "resources":  [
                                                           "config.js",
                                                           "logger.js",
                                                           "script.js"
                                                       ],
                                         "matches":  [
                                                         "\u003call_urls\u003e"
                                                     ]
                                     }
                                 ],
    "minimum_chrome_version":  "88"
}
